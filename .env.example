# ==========================================================
# Futuro del Este — variables de entorno
# Copiá este archivo a `.env` y completá con los datos de tu
# proyecto de Supabase (https://app.supabase.com → Project Settings → API).
# ==========================================================

# URL del proyecto Supabase (ej: https://xxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Clave pública "anon" (segura para el cliente; la seguridad real
# la aplican las políticas RLS de la base de datos)
VITE_SUPABASE_ANON_KEY=

# Código de equipo requerido para registrar cuentas de administrador.
# DEBE COINCIDIR con el secreto del servidor guardado en la tabla
# app_secrets (clave 'admin_signup_code'). La validación real ocurre en
# el servidor; este valor sólo da feedback inmediato en el formulario.
# Cambialo por uno propio antes de producción (en ambos lados).
VITE_ADMIN_TEAM_CODE=FDE2026
